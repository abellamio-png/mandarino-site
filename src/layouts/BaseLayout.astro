---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Import local fonts to get correctly hashed URLs for preloading
import loraFontSrc from '../assets/fonts/lora/lora-latin-400-normal.woff2?url';
import workSansFontSrc from '../assets/fonts/work-sans/work-sans-latin-400-normal.woff2?url';

interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
}

const { title, description, path, ogImage = 'https://mandarino.agency/placeholder-og.jpg' } = Astro.props;
const canonicalURL = `https://mandarino.agency${path}`;

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Mandarino",
  "legalName": "Mandarino ADV S.r.l.",
  "url": "https://mandarino.agency",
  "logo": "https://mandarino.agency/logo.svg",
  "email": "info@mandarino.agency",
  "telephone": "+39 0773 665106",
  "vatID": "IT02345120592",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Via Le Corbusier 393 scala B",
    "addressLocality": "Latina",
    "addressRegion": "LT",
    "postalCode": "04100",
    "addressCountry": "IT"
  },
  "sameAs": [
    "[LINKEDIN URL DA DEFINIRE]",
    "[INSTAGRAM URL DA DEFINIRE]"
  ]
};
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} — Mandarino` : 'Mandarino'}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <ClientRouter />

    <!-- Open Graph -->
    <meta property="og:title" content={title ? `${title} — Mandarino` : 'Mandarino'} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="it_IT" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload critici: Lora e Work Sans (solo fallback principali per LCP) -->
    <link rel="preload" as="font" type="font/woff2" crossorigin="anonymous" href={loraFontSrc} />
    <link rel="preload" as="font" type="font/woff2" crossorigin="anonymous" href={workSansFontSrc} />

    <!-- JSON-LD Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  </head>
  <body>
    <div id="cursor-custom" aria-hidden="true"></div>

    <!-- Skip link accessibile per tastiera -->
    <a class="skip-link" href="#main">Salta al contenuto principale</a>

    <!-- Header Component -->
    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />
    
    <!-- Scroll Reveal Centralizzato -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
      );

      function initReveal() {
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
      }

      initReveal();
      document.addEventListener('astro:page-load', initReveal);
    </script>

    <script>
      function initCursor() {
        const cursor = document.getElementById('cursor-custom');
        if (cursor && window.matchMedia('(pointer: fine)').matches) {
          document.addEventListener('mousemove', e => {
            cursor.style.left = e.clientX + 'px';
            cursor.style.top = e.clientY + 'px';
          });
          document.addEventListener('mouseleave', () => cursor.style.opacity = '0');
          document.addEventListener('mouseenter', () => cursor.style.opacity = '1');
        } else if (cursor) {
          cursor.style.display = 'none';
          document.body.style.cursor = 'auto';
        }
      }

      initCursor();
      document.addEventListener('astro:page-load', initCursor);

      // Hero titles word-by-word animation
      function initHeroTitles() {
        document.querySelectorAll('.hero-title').forEach(el => {
          if (el.dataset.animated) return;
          el.dataset.animated = 'true';

          const words = el.textContent.trim().split(/\s+/);
          el.innerHTML = words
            .map((word, i) => 
              `<span class="hero-title-word" style="animation-delay: ${i * 80}ms">${word}</span>`
            )
            .join(' ');
        });
      }

      initHeroTitles();
      document.addEventListener('astro:page-load', initHeroTitles);
    </script>
  </body>
</html>
