---
// MediaVideo — video embed nel corpo di un case study
// Uso in MDX:
// YouTube:  <MediaVideo tipo="youtube" id="dQw4w9WgXcQ" didascalia="..." />
// Vimeo:    <MediaVideo tipo="vimeo" id="123456789" didascalia="..." />
// Nativo:   <MediaVideo tipo="nativo" src="/assets/lavori/video.mp4" didascalia="..." />

interface Props {
  tipo: 'youtube' | 'vimeo' | 'nativo';
  id?: string;       // per youtube e vimeo
  src?: string;      // per video nativi
  didascalia?: string;
  autoplay?: boolean; // solo per video nativi, default false
}

const {
  tipo,
  id: rawId,
  src,
  didascalia,
  autoplay = false
} = Astro.props;

// Helper per estrarre l'ID da un URL YouTube (supporta watch?v=, youtu.be, embed, shorts)
function extractYoutubeId(input: string) {
  if (!input) return '';
  if (input.length <= 15 && !input.includes('/') && !input.includes('.')) return input;
  const regex = /(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/|youtube\.com\/shorts\/)([^"&?\/\s]{11})/i;
  const match = input.match(regex);
  return match ? match[1] : input;
}

// Helper per estrarre l'ID da un URL Vimeo
function extractVimeoId(input: string) {
  if (!input) return '';
  if (input.length <= 12 && !input.includes('/') && !input.includes('.')) return input;
  const regex = /(?:vimeo\.com\/|player\.vimeo\.com\/video\/)([0-9]+)/i;
  const match = input.match(regex);
  return match ? match[1] : input;
}

const finalId = tipo === 'youtube' ? extractYoutubeId(rawId || '') : extractVimeoId(rawId || '');

const isValidId = finalId && finalId.length > 0;

const youtubeUrl = (tipo === 'youtube' && isValidId)
  ? `https://www.youtube-nocookie.com/embed/${finalId}?rel=0&modestbranding=1`
  : null;

const vimeoUrl = (tipo === 'vimeo' && isValidId)
  ? `https://player.vimeo.com/video/${finalId}?byline=0&portrait=0&title=0`
  : null;
---

<figure class="media-video">
  <div class="media-video-frame">
    {tipo === 'youtube' && (
      <iframe
        src={youtubeUrl}
        title={didascalia || 'Video del progetto'}
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    )}

    {tipo === 'vimeo' && (
      <iframe
        src={vimeoUrl}
        title={didascalia || 'Video del progetto'}
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    )}

    {tipo === 'nativo' && src && (
      <video
        src={src}
        controls
        autoplay={autoplay}
        muted={autoplay}
        loop={autoplay}
        playsinline
        preload="metadata"
      >
        Il tuo browser non supporta il tag video.
      </video>
    )}
  </div>

  {didascalia && (
    <figcaption class="media-didascalia">{didascalia}</figcaption>
  )}
</figure>

<style>
  .media-video {
    margin: var(--space-10) 0;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Wrapper 16:9 responsivo */
  .media-video-frame {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
    background: var(--color-grigio-saggio);
    overflow: hidden;
  }

  .media-video-frame iframe,
  .media-video-frame video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  /* Per i video nativi non serve il padding-bottom trick */
  .media-video-frame:has(video) {
    padding-bottom: 0;
    height: auto;
  }

  .media-video-frame video {
    position: static;
    width: 100%;
    height: auto;
  }

  .media-didascalia {
    font-family: var(--font-ribelle);
    font-size: var(--text-sm);
    color: var(--color-grigio-saggio-soft);
    margin-top: var(--space-3);
    text-align: center;
    font-style: italic;
  }
</style>
