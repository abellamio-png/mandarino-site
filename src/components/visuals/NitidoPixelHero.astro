---
interface Props {
  showLabels?: boolean;
}
const { showLabels = false } = Astro.props;
---

<figure class="nitido-pixel-composition" aria-hidden="true">
  <svg viewBox="-80 0 1360 850" xmlns="http://www.w3.org/2000/svg"
       class="nitido-pixel-svg">
    
    <style>
      .outline { fill: none; stroke: #1a1a1a; stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; }
      .fill-body { fill: #FAF7F2; }
      .fill-ombra { fill: #2E4057; }
      .fill-verde { fill: #2D6A4F; }
      .fill-arancio { fill: #E87722; }
      .fill-grigio { fill: #2E4057; }
      .fill-rosa { fill: #E8729A; }
    </style>

    <!-- NITIDO: grande cerchio grigio saggio - POSIZIONATO PER NON ESSERE TAGLIATO -->
    <circle cx="280" cy="500" r="320" fill="var(--color-grigio-saggio)"/>

    <!-- PIXEL: forma a gradini arancio ribelle - ANCORATA IN BASSO -->
    <rect x="760" y="550" width="500" height="200" fill="var(--color-arancio-ribelle)"/>
    <rect x="840" y="390" width="420" height="160" fill="var(--color-arancio-ribelle)"/>
    <rect x="940" y="270" width="320" height="120" fill="var(--color-arancio-ribelle)"/>
    <rect x="1060" y="190" width="200" height="80"  fill="var(--color-arancio-ribelle)"/>

    <!-- PERSONAGGIO SAGGIO (dentro il cerchio Nitido) -->
    <g class="saggio-embed" transform="translate(180, 280) scale(0.65)">
       <ellipse cx="108" cy="365" rx="32" ry="18" class="fill-ombra"/>
       <ellipse cx="108" cy="365" rx="32" ry="18" class="outline"/>
       <ellipse cx="192" cy="365" rx="32" ry="18" class="fill-ombra"/>
       <ellipse cx="192" cy="365" rx="32" ry="18" class="outline"/>
       <ellipse cx="82" cy="371" rx="18" ry="10" class="fill-ombra"/>
       <ellipse cx="82" cy="371" rx="18" ry="10" class="outline"/>
       <ellipse cx="218" cy="371" rx="18" ry="10" class="fill-ombra"/>
       <ellipse cx="218" cy="371" rx="18" ry="10" class="outline"/>
       <ellipse cx="150" cy="315" rx="52" ry="38" class="fill-body"/>
       <ellipse cx="150" cy="315" rx="52" ry="38" class="outline"/>
       <g class="saggio-testa-anim">
         <path d="M108 305 Q75 290 62 303" class="fill-body" stroke="#1a1a1a" stroke-width="3" stroke-linecap="round"/>
         <ellipse cx="58" cy="307" rx="12" ry="10" class="fill-body"/>
         <ellipse cx="58" cy="307" rx="12" ry="10" class="outline"/>
         <path d="M192 305 Q225 290 238 303" class="fill-body" stroke="#1a1a1a" stroke-width="3" stroke-linecap="round"/>
         <ellipse cx="242" cy="307" rx="12" ry="10" class="fill-body"/>
         <ellipse cx="242" cy="307" rx="12" ry="10" class="outline"/>
         <rect x="138" y="261" width="24" height="22" rx="4" class="fill-body"/>
         <rect x="138" y="261" width="24" height="22" rx="4" class="outline"/>
         <ellipse cx="150" cy="225" rx="56" ry="58" class="fill-verde"/>
         <ellipse cx="150" cy="225" rx="56" ry="58" class="outline"/>
         <path d="M132 218 Q138 212 144 218" fill="none" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round"/>
         <path d="M156 218 Q162 212 168 218" fill="none" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round"/>
         <path d="M133 242 Q150 255 167 242" fill="none" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round"/>
       </g>
    </g>

    <!-- PERSONAGGIO RIBELLE (seduto su un gradino Pixel) -->
    <g class="ribelle-embed" transform="translate(745, 125) scale(0.68)">
       <rect x="120" y="355" width="100" height="60" class="fill-arancio"/>
       <rect x="120" y="355" width="100" height="60" class="outline"/>
       <rect x="180" y="390" width="60" height="30" class="fill-arancio"/>
       <rect x="180" y="390" width="60" height="30" class="outline"/>
       <path d="M152 338 Q132 363 126 383" fill="none" stroke="#1a1a1a" stroke-width="12" stroke-linecap="round"/>
       <ellipse cx="126" cy="386" rx="14" ry="9" class="fill-ombra"/>
       <ellipse cx="126" cy="386" rx="14" ry="9" class="outline"/>
       <path d="M188 338 Q208 363 214 383" fill="none" stroke="#1a1a1a" stroke-width="12" stroke-linecap="round"/>
       <ellipse cx="214" cy="386" rx="14" ry="9" class="fill-ombra"/>
       <ellipse cx="214" cy="386" rx="14" ry="9" class="outline"/>
       <ellipse cx="170" cy="315" rx="52" ry="38" class="fill-body"/>
       <ellipse cx="170" cy="315" rx="52" ry="38" class="outline"/>
       <g class="ribelle-body-anim">
         <path d="M128 298 Q100 265 104 244" fill="none" stroke="#1a1a1a" stroke-width="11" stroke-linecap="round"/>
         <ellipse cx="105" cy="238" rx="11" ry="13" class="fill-body"/>
         <ellipse cx="105" cy="238" rx="11" ry="13" class="outline"/>
         <line x1="105" y1="225" x2="105" y2="210" stroke="#1a1a1a" stroke-width="6" stroke-linecap="round"/>
         <rect x="158" y="261" width="24" height="22" rx="4" class="fill-body"/>
         <rect x="158" y="261" width="24" height="22" rx="4" class="outline"/>
         <ellipse cx="170" cy="222" rx="56" ry="58" class="fill-arancio"/>
         <ellipse cx="170" cy="222" rx="56" ry="58" class="outline"/>
         <path d="M116 222 Q118 162 170 160 Q222 162 224 222" fill="none" stroke="#E8729A" stroke-width="7" stroke-linecap="round"/>
         <rect x="103" y="212" width="22" height="30" rx="8" class="fill-rosa"/>
         <rect x="103" y="212" width="22" height="30" rx="8" class="outline" stroke-width="2.5"/>
         <rect x="215" y="212" width="22" height="30" rx="8" class="fill-rosa"/>
         <rect x="215" y="212" width="22" height="30" rx="8" class="outline" stroke-width="2.5"/>
         <circle cx="154" cy="216" r="9" class="fill-grigio"/>
         <circle cx="186" cy="216" r="9" class="fill-grigio"/>
         <path d="M148 240 Q170 257 192 240" fill="none" stroke="#1a1a1a" stroke-width="3" stroke-linecap="round"/>
       </g>
    </g>

  </svg>


  {showLabels && (
    <div class="nitido-pixel-labels">
      <div class="label-nitido">
        <span class="label-sistema">Nitido: Saggio,</span>
        <strong class="label-ruolo">il Generale.</strong>
        <p class="label-desc">La forma nitida rappresenta l'ordine, la chiarezza,
        il risultato finale frutto dell'esperienza e della saggezza.
        È la visione d'insieme, l'architettura completata.</p>
      </div>
      <div class="label-pixel">
        <span class="label-sistema">Pixel: Ribelle,</span>
        <strong class="label-ruolo">il Particolare.</strong>
        <p class="label-desc">Il pixel rappresenta il caos creativo, l'elemento
        grezzo, l'inizio non convenzionale. È il dettaglio, il singolo mattone.</p>
      </div>
    </div>
  )}
</figure>

<style>
  .nitido-pixel-composition {
    margin: 0;
    padding: 0;
    overflow: hidden;
  }

  .nitido-pixel-svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  /* Animazioni Saggio */
  .saggio-testa-anim {
    animation: saggio-respiro 4s ease-in-out infinite;
    transform-origin: 150px 225px;
  }
  @keyframes saggio-respiro {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-8px); }
  }

  /* Animazioni Ribelle */
  .ribelle-body-anim {
    animation: ribelle-ritmo 0.6s ease-in-out infinite alternate;
    transform-origin: 170px 315px;
  }
  @keyframes ribelle-ritmo {
    from { transform: rotate(-1.5deg); }
    to   { transform: rotate(1.5deg); }
  }

  /* Label styles */
  .nitido-pixel-labels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    padding: var(--space-12) var(--space-4);
    background-color: var(--color-bianco-sporco);
  }

  .label-sistema {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-grigio-saggio-soft);
    letter-spacing: 0.05em;
    margin-bottom: 4px;
    font-family: var(--font-ribelle);
  }

  .label-ruolo {
    display: block;
    font-family: var(--font-saggio);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-3);
  }

  .label-nitido .label-ruolo { color: var(--color-grigio-saggio); }
  .label-pixel .label-ruolo { color: var(--color-arancio-ribelle); }

  .label-desc {
    font-size: var(--text-base);
    color: var(--color-grigio-saggio-soft);
    line-height: var(--leading-relaxed);
    max-width: 45ch;
  }

  @media (max-width: 768px) {
    .nitido-pixel-labels {
      grid-template-columns: 1fr;
      padding-top: var(--space-8);
    }
  }
</style>
