---
// Personaggio Saggio — il mandarino meditante
// Basato sul design ufficiale saggio.svg
---

<svg
  viewBox="0 0 340 460"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class="personaggio-saggio"
>
  <style>
    .personaggio-saggio .outline { fill: none; stroke: #1a1a1a; stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; }
    .personaggio-saggio .fill-verde { fill: #2D6A4F; }
    .personaggio-saggio .fill-body { fill: #FAF7F2; }
    .personaggio-saggio .fill-ombra { fill: #2E4057; }
    .personaggio-saggio .fill-giallo { fill: #F4C430; }
    .personaggio-saggio .pixel { fill: #2D8659; }
  </style>

  <!-- Pixel/scacchiera in alto a sinistra -->
  <rect x="10" y="10" width="28" height="28" class="pixel" rx="2"/>
  <rect x="46" y="10" width="28" height="28" class="pixel" rx="2" opacity="0.5"/>
  <rect x="10" y="46" width="28" height="28" class="pixel" rx="2" opacity="0.5"/>
  <rect x="46" y="46" width="28" height="28" class="pixel" rx="2"/>

  <!-- Gamba sinistra -->
  <ellipse cx="108" cy="365" rx="32" ry="18" class="fill-ombra"/>
  <ellipse cx="108" cy="365" rx="32" ry="18" class="outline"/>
  <!-- Gamba destra -->
  <ellipse cx="192" cy="365" rx="32" ry="18" class="fill-ombra"/>
  <ellipse cx="192" cy="365" rx="32" ry="18" class="outline"/>
  <!-- Piede sx -->
  <ellipse cx="82" cy="371" rx="18" ry="10" class="fill-ombra"/>
  <ellipse cx="82" cy="371" rx="18" ry="10" class="outline"/>
  <!-- Piede dx -->
  <ellipse cx="218" cy="371" rx="18" ry="10" class="fill-ombra"/>
  <ellipse cx="218" cy="371" rx="18" ry="10" class="outline"/>

  <!-- Torso -->
  <ellipse cx="150" cy="315" rx="52" ry="38" class="fill-body"/>
  <ellipse cx="150" cy="315" rx="52" ry="38" class="outline"/>

  <!-- Braccia Meditative -->
  <g class="braccia-meditazione">
    <!-- Braccio sinistro aperto -->
    <path d="M108 305 Q75 290 62 303" class="fill-body" stroke="#1a1a1a" stroke-width="3" stroke-linecap="round"/>
    <ellipse cx="58" cy="307" rx="12" ry="10" class="fill-body"/>
    <ellipse cx="58" cy="307" rx="12" ry="10" class="outline"/>
    <!-- Braccio destro aperto -->
    <path d="M192 305 Q225 290 238 303" class="fill-body" stroke="#1a1a1a" stroke-width="3" stroke-linecap="round"/>
    <ellipse cx="242" cy="307" rx="12" ry="10" class="fill-body"/>
    <ellipse cx="242" cy="307" rx="12" ry="10" class="outline"/>
  </g>

  <!-- Collo -->
  <rect x="138" y="261" width="24" height="22" rx="4" class="fill-body"/>
  <rect x="138" y="261" width="24" height="22" rx="4" class="outline"/>

  <!-- Testa mandarino verde -->
  <g class="testa-saggio">
    <ellipse cx="150" cy="225" rx="56" ry="58" class="fill-verde"/>
    <ellipse cx="150" cy="225" rx="56" ry="58" class="outline"/>

    <!-- Texture mandarino -->
    <path d="M150 168 Q142 196 150 225 Q158 196 150 168" fill="none" stroke="#1E4D3A" stroke-width="2"/>
    <path d="M134 171 Q122 200 128 225" fill="none" stroke="#1E4D3A" stroke-width="1.5"/>
    <path d="M166 171 Q178 200 172 225" fill="none" stroke="#1E4D3A" stroke-width="1.5"/>

    <!-- Fogliolina -->
    <path d="M150 167 Q145 150 150 143 Q155 150 150 167" fill="#1E4D3A" stroke="#1a1a1a" stroke-width="2"/>
    <path d="M150 162 Q140 148 133 145 Q138 155 150 162" fill="#1E4D3A" stroke="#1a1a1a" stroke-width="1.5"/>

    <!-- Occhi chiusi -->
    <path d="M132 218 Q138 212 144 218" fill="none" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round"/>
    <path d="M156 218 Q162 212 168 218" fill="none" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round"/>

    <!-- Sorriso sereno -->
    <path d="M133 242 Q150 255 167 242" fill="none" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round"/>
  </g>

  <!-- Farfalla gialla -->
  <g class="farfalla-saggio">
    <path d="M82 190 Q70 178 78 173 Q86 178 82 190" fill="#F4C430" stroke="#1a1a1a" stroke-width="1.5"/>
    <path d="M82 190 Q94 178 86 173 Q78 178 82 190" fill="#F4C430" stroke="#1a1a1a" stroke-width="1.5"/>
    <circle cx="82" cy="190" r="2.5" fill="#1a1a1a"/>
  </g>

  <!-- Label (opzionale se mostrata standalone) -->
  <text x="150" y="425" text-anchor="middle" font-family="var(--font-ribelle)" font-size="11" letter-spacing="3" fill="#2E4057" font-weight="500">SAGGIO</text>
</svg>

<style>
  .personaggio-saggio {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  /* Animazione Meditazione — respiro leggero */
  .testa-saggio {
    animation: saggio-breathing 4s ease-in-out infinite;
    transform-origin: 150px 225px;
  }
  @keyframes saggio-breathing {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-5px); }
  }

  /* Farfalla — fluttua */
  .farfalla-saggio {
    animation: saggio-farfalla 3s ease-in-out infinite;
    transform-origin: 82px 190px;
  }
  @keyframes saggio-farfalla {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50%       { transform: translate(-10px, -15px) rotate(-10deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .testa-saggio, .farfalla-saggio {
      animation: none;
    }
  }
</style>
