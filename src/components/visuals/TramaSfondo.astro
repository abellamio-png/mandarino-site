---
interface Props {
  variante?: 'chiaro' | 'scuro';
  opacita?: number;
}
const { variante = 'chiaro', opacita = 0.06 } = Astro.props;

const coloreSaggio = variante === 'scuro' ? '#FAF7F2' : '#2E4057';
const coloreRibelle = variante === 'scuro' ? '#FAF7F2' : '#E87722';
---

<svg
  class="trama-sfondo"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <pattern
      id={`trama-${variante}`}
      x="0" y="0"
      width="120" height="120"
      patternUnits="userSpaceOnUse"
    >
      <!-- SAGGIO — cerchi morbidi, posizioni irregolari -->
      <circle cx="18" cy="22" r="10"
        fill="none"
        stroke={coloreSaggio}
        stroke-width="1.5"
        opacity={opacita * 1.2}
      />
      <circle cx="88" cy="55" r="16"
        fill="none"
        stroke={coloreSaggio}
        stroke-width="1"
        opacity={opacita}
      />
      <circle cx="42" cy="98" r="7"
        fill={coloreSaggio}
        opacity={opacita * 0.8}
      />

      <!-- RIBELLE — gradini spigolosi + blocchi pixel -->

      <!-- Gradino piccolo in alto a destra -->
      <path
        d="M96 8 L108 8 L108 16 L116 16 L116 26"
        fill="none"
        stroke={coloreRibelle}
        stroke-width="2"
        stroke-linecap="square"
        opacity={opacita * 1.5}
      />

      <!-- Gradino medio in basso a sinistra -->
      <path
        d="M4 72 L14 72 L14 82 L26 82 L26 94 L38 94"
        fill="none"
        stroke={coloreRibelle}
        stroke-width="1.5"
        stroke-linecap="square"
        opacity={opacita}
      />

      <!-- Blocchi pixel a gradino nel centro -->
      <rect x="60" y="28" width="8" height="8"
        fill={coloreRibelle} opacity={opacita * 1.2}
      />
      <rect x="68" y="36" width="8" height="8"
        fill={coloreRibelle} opacity={opacita * 0.9}
      />
      <rect x="76" y="36" width="8" height="8"
        fill={coloreRibelle} opacity={opacita * 0.6}
      />
    </pattern>
  </defs>

  <rect width="100%" height="100%" fill={`url(#trama-${variante})`}/>
</svg>

<style>
  .trama-sfondo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
</style>
