<svg
  viewBox="0 0 220 280"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class="personaggio-ribelle"
>
  <!-- Ombra sotto il Ribelle -->
  <ellipse cx="110" cy="260" rx="58" ry="12" fill="rgba(0,0,0,0.25)"/>

  <!-- Corpo -->
  <rect x="60" y="212" width="100" height="80" rx="5" fill="#3D566E"/>
  <line x1="60" y1="242" x2="160" y2="242" stroke="rgba(250,247,242,0.1)" stroke-width="1"/>

  <!-- Gambe e Scarpe -->
  <rect x="75" y="287" width="24" height="14" rx="3" fill="#2A3F52"/>
  <rect x="131" y="287" width="24" height="14" rx="3" fill="#2A3F52"/>
  <rect x="71" y="297" width="30" height="10" rx="4" fill="#1A2A38"/>
  <rect x="127" y="297" width="30" height="10" rx="4" fill="#1A2A38"/>

  <!-- Braccio sinistro -->
  <path d="M62 222 Q35 236 30 254 Q30 262 38 262"
    fill="none" stroke="#FAF7F2" stroke-width="3.5"
    stroke-linecap="round"/>
  <circle cx="38" cy="264" r="8" fill="#FAF7F2" opacity="0.9"/>

  <!-- Braccio destro — ALZATO -->
  <g class="braccio-alzato-group">
    <path d="M158 220 Q184 200 190 178 Q192 164 184 160"
      fill="none" stroke="#FAF7F2" stroke-width="3.5"
      stroke-linecap="round" class="braccio-alzato"/>
    <circle cx="183" cy="158" r="9" fill="#FAF7F2" opacity="0.9"/>
    <line x1="183" y1="149" x2="183" y2="136"
      stroke="#FAF7F2" stroke-width="2.5" stroke-linecap="round"
      class="dito"/>
  </g>

  <!-- Testa arancio -->
  <ellipse cx="110" cy="112" rx="64" ry="66" fill="#E87722"/>

  <!-- Texture mandarino -->
  <path d="M110 46 Q101 76 110 112 Q119 76 110 46"
    fill="none" stroke="rgba(255,255,255,0.18)" stroke-width="1.5"/>
  <path d="M96 48 Q82 78 88 112"
    fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
  <path d="M124 48 Q138 78 132 112"
    fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>

  <!-- Fogliolina -->
  <path d="M110 45 Q104 31 110 26 Q116 31 110 45" fill="#C0551A"/>
  <path d="M110 40 Q102 28 96 26 Q100 34 110 40" fill="#C0551A"/>

  <!-- CUFFIE -->
  <path d="M46 110 Q46 42 110 42 Q174 110 174 110"
    fill="none" stroke="#2E4057" stroke-width="7"
    stroke-linecap="round"/>
  <rect x="33" y="100" width="20" height="28" rx="7"
    fill="#2E4057" stroke="#FAF7F2" stroke-width="1.5"/>
  <rect x="207" y="100" width="20" height="28" rx="7"
    fill="#2E4057" stroke="#FAF7F2" stroke-width="1.5"/>
  
  <!-- Microfono -->
  <path d="M207 118 Q222 118 226 128"
    fill="none" stroke="#2E4057" stroke-width="2.5"
    stroke-linecap="round"/>
  <circle cx="227" cy="130" r="4.5" fill="#E87722" class="led"/>

  <!-- Occhi aperti -->
  <circle cx="92" cy="110" r="7.5" fill="#2E4057"/>
  <circle cx="128" cy="110" r="7.5" fill="#2E4057"/>
  <circle cx="94" cy="108" r="3" fill="#FAF7F2"/>
  <circle cx="130" cy="108" r="3" fill="#FAF7F2"/>

  <!-- Sorriso -->
  <path d="M88 130 Q110 144 132 130"
    fill="none" stroke="#2E4057" stroke-width="3"
    stroke-linecap="round"/>

  <!-- Pixel -->
  <rect x="194" y="136" width="8"  height="8"  fill="#E87722" class="pixel" style="animation-delay: 0s" opacity="0.9"/>
  <rect x="206" y="126" width="6"  height="6"  fill="#E87722" class="pixel" style="animation-delay: 0.2s" opacity="0.6"/>
</svg>

<style>
  .personaggio-ribelle {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  /* Braccio alzato */
  .braccio-alzato-group {
    animation: braccio 2.8s ease-in-out infinite;
    transform-origin: 158px 220px;
  }
  @keyframes braccio {
    0%, 100% { transform: rotate(0deg); }
    35%       { transform: rotate(-7deg); }
    65%       { transform: rotate(3deg); }
  }

  /* Led microfono */
  .led {
    animation: led-blink 4s ease-in-out infinite;
  }
  @keyframes led-blink {
    0%, 88%, 100% { opacity: 1; }
    92%            { opacity: 0.1; }
  }

  /* Pixel */
  .pixel {
    animation: pixel-pulse 3s ease-in-out infinite;
  }
  @keyframes pixel-pulse {
    0%, 100% { opacity: 0.8; }
    50%       { opacity: 0.15; }
  }

  @media (prefers-reduced-motion: reduce) {
    .braccio-alzato-group, .led, .pixel {
      animation: none;
    }
  }
</style>

