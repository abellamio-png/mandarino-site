---
// Personaggio Ribelle — il mandarino creativo
// Basato sul design ufficiale ribelle.svg
---

<svg
  viewBox="0 0 340 460"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class="personaggio-ribelle"
>
  <style>
    .personaggio-ribelle .outline { fill: none; stroke: #1a1a1a; stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; }
    .personaggio-ribelle .fill-arancio { fill: #E87722; }
    .personaggio-ribelle .fill-grigio { fill: #2E4057; }
    .personaggio-ribelle .fill-body { fill: #FAF7F2; }
    .personaggio-ribelle .fill-ombra { fill: #2E4057; }
    .personaggio-ribelle .fill-rosa { fill: #E8729A; }
  </style>

  <!-- Blocco arancione sotto -->
  <rect x="120" y="355" width="100" height="60" class="fill-arancio"/>
  <rect x="120" y="355" width="100" height="60" class="outline"/>
  <rect x="180" y="390" width="60" height="30" class="fill-arancio"/>
  <rect x="180" y="390" width="60" height="30" class="outline"/>

  <!-- Gambe penzolanti -->
  <g class="gambe-ribelle">
    <path d="M152 338 Q132 363 126 383" fill="none" stroke="#1a1a1a" stroke-width="12" stroke-linecap="round"/>
    <ellipse cx="126" cy="386" rx="14" ry="9" class="fill-ombra"/>
    <ellipse cx="126" cy="386" rx="14" ry="9" class="outline"/>
    <path d="M188 338 Q208 363 214 383" fill="none" stroke="#1a1a1a" stroke-width="12" stroke-linecap="round"/>
    <ellipse cx="214" cy="386" rx="14" ry="9" class="fill-ombra"/>
    <ellipse cx="214" cy="386" rx="14" ry="9" class="outline"/>
  </g>

  <!-- Torso -->
  <ellipse cx="170" cy="315" rx="52" ry="38" class="fill-body"/>
  <ellipse cx="170" cy="315" rx="52" ry="38" class="outline"/>

  <!-- Braccia -->
  <g class="braccia-ribelle">
    <!-- Braccio sinistro alzato con dito -->
    <path d="M128 298 Q100 265 104 244" fill="none" stroke="#1a1a1a" stroke-width="11" stroke-linecap="round" class="avambraccio-sx"/>
    <ellipse cx="105" cy="238" rx="11" ry="13" class="fill-body"/>
    <ellipse cx="105" cy="238" rx="11" ry="13" class="outline"/>
    <line x1="105" y1="225" x2="105" y2="210" stroke="#1a1a1a" stroke-width="6" stroke-linecap="round" class="dito"/>

    <!-- Braccio destro al mento -->
    <path d="M212 305 Q240 302 247 315" fill="none" stroke="#1a1a1a" stroke-width="11" stroke-linecap="round"/>
    <ellipse cx="251" cy="319" rx="13" ry="11" class="fill-body"/>
    <ellipse cx="251" cy="319" rx="13" ry="11" class="outline"/>
  </g>

  <!-- Collo -->
  <rect x="158" y="261" width="24" height="22" rx="4" class="fill-body"/>
  <rect x="158" y="261" width="24" height="22" rx="4" class="outline"/>

  <!-- Testa mandarino arancio -->
  <g class="testa-ribelle">
    <ellipse cx="170" cy="222" rx="56" ry="58" class="fill-arancio"/>
    <ellipse cx="170" cy="222" rx="56" ry="58" class="outline"/>

    <!-- Texture mandarino -->
    <path d="M170 165 Q162 194 170 222 Q178 194 170 165" fill="none" stroke="#C05A0A" stroke-width="2"/>
    <path d="M154 168 Q142 198 148 222" fill="none" stroke="#C05A0A" stroke-width="1.5"/>
    <path d="M186 168 Q198 198 192 222" fill="none" stroke="#C05A0A" stroke-width="1.5"/>

    <!-- Fogliolina arancio -->
    <path d="M170 164 Q165 147 170 140 Q175 147 170 164" fill="#C05A0A" stroke="#1a1a1a" stroke-width="2"/>
    <path d="M170 159 Q160 145 153 142 Q158 152 170 159" fill="#C05A0A" stroke="#1a1a1a" stroke-width="1.5"/>

    <!-- Cuffie rosa — archetto -->
    <path d="M116 222 Q118 162 170 160 Q222 162 224 222" fill="none" stroke="#E8729A" stroke-width="7" stroke-linecap="round"/>
    <!-- Padiglione sinistro -->
    <rect x="103" y="212" width="22" height="30" rx="8" class="fill-rosa"/>
    <rect x="103" y="212" width="22" height="30" rx="8" class="outline" stroke-width="2.5"/>
    <!-- Padiglione destro -->
    <rect x="215" y="212" width="22" height="30" rx="8" class="fill-rosa"/>
    <rect x="215" y="212" width="22" height="30" rx="8" class="outline" stroke-width="2.5"/>
    <!-- Microfono -->
    <path d="M237 227 Q252 227 256 237" fill="none" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round"/>
    <circle cx="258" cy="239" r="5" class="fill-arancio" stroke="#1a1a1a" stroke-width="2" class="led"/>

    <!-- Occhi -->
    <circle cx="154" cy="216" r="9" class="fill-grigio"/>
    <circle cx="186" cy="216" r="9" class="fill-grigio"/>
    <circle cx="156" cy="214" r="3.5" fill="#FAF7F2"/>
    <circle cx="188" cy="214" r="3.5" fill="#FAF7F2"/>

    <!-- Sorriso -->
    <path d="M148 240 Q170 257 192 240" fill="none" stroke="#1a1a1a" stroke-width="3" stroke-linecap="round"/>
  </g>

  <!-- Label (opzionale) -->
  <text x="170" y="428" text-anchor="middle" font-family="var(--font-ribelle)" font-size="11" letter-spacing="3" fill="#E87722" font-weight="500">RIBELLE</text>
</svg>

<style>
  .personaggio-ribelle {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  /* Animazione Testa — ritmo cuffie */
  .testa-ribelle {
    animation: ribelle-beat 0.6s ease-in-out infinite alternate;
    transform-origin: 170px 260px;
  }
  @keyframes ribelle-beat {
    from { transform: rotate(-2deg); }
    to   { transform: rotate(2deg); }
  }

  /* Braccio che indica */
  .avambraccio-sx {
    animation: ribelle-point 3s ease-in-out infinite;
    transform-origin: 128px 298px;
  }
  @keyframes ribelle-point {
    0%, 100% { transform: rotate(0deg); }
    50%       { transform: rotate(-5deg); }
  }

  /* Microfono led — lampeggia */
  .led {
    animation: ribelle-led 4s ease-in-out infinite;
  }
  @keyframes ribelle-led {
    0%, 88%, 100% { opacity: 1; }
    92%            { opacity: 0.1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .testa-ribelle, .avambraccio-sx, .led {
      animation: none;
    }
  }
</style>
