---
// Personaggio Ribelle — la volpe con cuffie
// Usato nella sezione Ribelli della pagina Agenzia
---

<svg
  viewBox="0 0 120 140"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class="personaggio-ribelle"
>
  <!-- Corpo in piedi (rettangolo arrotondato) -->
  <rect x="35" y="75" width="50" height="50" rx="4" fill="none" stroke="#2E4057" stroke-width="2.5"/>

  <!-- Testa (mandarino arancio) -->
  <circle cx="60" cy="50" r="24" fill="none" stroke="#2E4057" stroke-width="2.5"/>

  <!-- Cuffie -->
  <path d="M36 50 Q36 26 60 26 Q84 26 84 50" fill="none" stroke="#2E4057" stroke-width="3" stroke-linecap="round"/>
  <rect x="28" y="44" width="12" height="16" rx="4" fill="none" stroke="#2E4057" stroke-width="2"/>
  <rect x="80" y="44" width="12" height="16" rx="4" fill="none" stroke="#2E4057" stroke-width="2"/>

  <!-- Occhi (aperti, vivaci) -->
  <circle cx="51" cy="50" r="3.5" fill="#2E4057"/>
  <circle cx="69" cy="50" r="3.5" fill="#2E4057"/>
  <!-- Luce negli occhi -->
  <circle cx="52.5" cy="48.5" r="1" fill="#FAF7F2"/>
  <circle cx="70.5" cy="48.5" r="1" fill="#FAF7F2"/>

  <!-- Sorriso aperto -->
  <path d="M51 58 Q60 66 69 58" fill="none" stroke="#2E4057" stroke-width="2" stroke-linecap="round"/>

  <!-- Braccio alzato (energia) -->
  <path d="M35 80 Q20 65 25 50" fill="none" stroke="#2E4057" stroke-width="2.5" stroke-linecap="round"/>
  <!-- Mano alzata -->
  <circle cx="25" cy="48" r="6" fill="none" stroke="#2E4057" stroke-width="2"/>

  <!-- Pixel decorativi (sistema Nitido/Pixel) -->
  <rect x="95" y="30" width="8" height="8" fill="#E87722"/>
  <rect x="105" y="30" width="8" height="8" fill="#E87722"/>
  <rect x="105" y="20" width="8" height="8" fill="#E87722"/>
</svg>
