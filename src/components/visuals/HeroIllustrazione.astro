---
import PersonaggioSaggio from './PersonaggioSaggio.astro';
import PersonaggioRibelle from './PersonaggioRibelle.astro';

// HeroIllustrazione — composizione prospettica Saggio + Ribelle
// Ribelle in primo piano (grande, destra), Saggio sullo sfondo (piccolo, sinistra)
// Linea di terra comune — stessa scena, stessa storia
---

<div class="hero-scene" aria-hidden="true">
  
  <!-- Personaggi come componenti indipendenti -->
  <div class="character-wrap character-wrap--saggio">
    <PersonaggioSaggio />
    <span class="character-label">SAGGIO</span>
  </div>

  <div class="character-wrap character-wrap--ribelle">
    <PersonaggioRibelle />
    <span class="character-label">RIBELLE</span>
  </div>

  <!-- Sfondo e decorazioni (SVG per griglia, pixel e linea di terra) -->
  <svg
    viewBox="0 0 520 460"
    xmlns="http://www.w3.org/2000/svg"
    class="scene-base"
  >
    <!-- SFONDO — Rimosso per layout coeso -->
    
    <!-- Griglia di sfondo — Rimossa per layout coeso -->


    <!-- PIXEL — direzione diagonale Saggio → Ribelle (filo di pensiero) -->
    <rect x="180" y="240" width="10" height="10" fill="#E87722" class="pixel pixel-1"/>
    <rect x="200" y="252" width="8"  height="8"  fill="#E87722" class="pixel pixel-2"/>
    <rect x="220" y="262" width="6"  height="6"  fill="#E87722" class="pixel pixel-3"/>
    <rect x="238" y="270" width="5"  height="5"  fill="#E87722" class="pixel pixel-4"/>

    <!-- Cluster alto destra -->
    <rect x="440" y="44"  width="12" height="12" fill="#E87722" class="pixel pixel-5"/>
    <rect x="456" y="44"  width="12" height="12" fill="#E87722" class="pixel pixel-6"/>
    <rect x="456" y="60"  width="12" height="12" fill="#E87722" class="pixel pixel-7"/>

    <!-- Pixel isolati sinistra bassa -->
    <rect x="52"  y="360" width="8"  height="8"  fill="#E87722" class="pixel pixel-8" opacity="0.6"/>
    <rect x="64"  y="374" width="6"  height="6"  fill="#E87722" class="pixel pixel-9" opacity="0.4"/>

    <!-- LINEA DI TERRA — li unisce nella stessa scena -->
    <line x1="40" y1="392" x2="480" y2="392"
      stroke="rgba(46,64,87,0.15)" stroke-width="1"/>

    <!-- Firma -->
    <text x="260" y="452"
      font-family="'Work Sans', sans-serif"
      font-size="9" fill="rgba(46,64,87,0.18)"
      text-anchor="middle" letter-spacing="3">SAGGI E RIBELLI · DAL 2004</text>
  </svg>
</div>

<style>
  .hero-scene {
    position: relative;
    width: 100%;
    max-width: 520px;
    aspect-ratio: 520 / 460;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(20px);
    animation: hero-enter 800ms cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 500ms;
  }

  .scene-base {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Posizionamento personaggi */
  .character-wrap {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 10;
  }

  .character-wrap--saggio {
    width: 15.3%; /* Ripristinato scala originale */
    top: 47.4%;   /* Allineato alla linea di terra (300px / 460px) */
    left: 20%;
  }

  .character-wrap--ribelle {
    width: 25%;  /* Ridotto dal 38% per ripristinare la prospettiva */
    top: 56.1%;  /* Allineato alla linea di terra (418px / 460px) */
    right: 15%;
  }

  .character-label {
    font-family: 'Work Sans', sans-serif;
    font-size: 9px;
    color: rgba(46, 64, 87, 0.25);
    letter-spacing: 2px;
    margin-top: 5px;
  }

  @keyframes hero-enter {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Pixel animati (copiati dal hero originale) */
  .pixel { animation: pixel-pulse 3s ease-in-out infinite; }
  .pixel-1  { animation-delay: 0ms; }
  .pixel-2  { animation-delay: 180ms; }
  .pixel-3  { animation-delay: 360ms; }
  .pixel-4  { animation-delay: 540ms; }
  .pixel-5  { animation-delay: 200ms; }
  .pixel-6  { animation-delay: 400ms; }
  .pixel-7  { animation-delay: 600ms; }
  .pixel-8  { animation-delay: 100ms; }
  .pixel-9  { animation-delay: 300ms; }

  @keyframes pixel-pulse {
    0%, 100% { opacity: 0.8; }
    50%       { opacity: 0.15; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-scene, .pixel {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

