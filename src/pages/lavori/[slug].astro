---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PixelCluster from '../../components/visuals/PixelCluster.astro';
import MediaImmagine from '../../components/media/MediaImmagine.astro';
import MediaGallery from '../../components/media/MediaGallery.astro';
import MediaVideo from '../../components/media/MediaVideo.astro';
import '../../styles/pages/lavori.css';

export async function getStaticPaths() {
  const lavori = await getCollection('lavori', ({ data }) => !data.draft);
  return lavori.map(lavoro => ({
    params: { slug: lavoro.id },
    props: { lavoro },
  }));
}

interface Props {
  lavoro: CollectionEntry<'lavori'>;
}

const { lavoro } = Astro.props;
const { Content } = await render(lavoro);

// Trova case precedente e successivo nella vetrina
const tuttiVetrina = (await getCollection('lavori', ({ data }) => !data.draft && data.inVetrina))
  .sort((a, b) => (a.data.ordineVetrina || 999) - (b.data.ordineVetrina || 999));

const indexCorrente = tuttiVetrina.findIndex(l => l.id === lavoro.id);
const casePrec = indexCorrente > 0 ? tuttiVetrina[indexCorrente - 1] : null;
const caseSucc = indexCorrente < tuttiVetrina.length - 1 ? tuttiVetrina[indexCorrente + 1] : null;

// JSON-LD per CreativeWork
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": lavoro.data.titolo,
  "about": lavoro.data.cliente,
  "description": lavoro.data.descrizione,
  "creator": {
    "@type": "Organization",
    "name": "Mandarino",
    "url": "https://mandarino.agency"
  },
  "url": `https://mandarino.agency/lavori/${lavoro.id}/`,
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://mandarino.agency/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Lavori",
      "item": "https://mandarino.agency/lavori/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": lavoro.data.cliente,
      "item": `https://mandarino.agency/lavori/${lavoro.id}/`
    }
  ]
};
---

<BaseLayout
  title={`${lavoro.data.cliente} — ${lavoro.data.titolo}`}
  description={lavoro.data.descrizione}
  path={`/lavori/${lavoro.id}/`}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbLd)}
  />

  <article class="case-page">
    <!-- Breadcrumb -->
    <nav class="case-breadcrumb" aria-label="Percorso di navigazione">
      <ol class="breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/" itemprop="item">
            <span itemprop="name">Home</span>
          </a>
          <meta itemprop="position" content="1" />
        </li>
        <li aria-hidden="true">
          <span class="breadcrumb-separator">→</span>
        </li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/lavori/" itemprop="item">
            <span itemprop="name">Lavori</span>
          </a>
          <meta itemprop="position" content="2" />
        </li>
        <li aria-hidden="true">
          <span class="breadcrumb-separator">→</span>
        </li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span itemprop="name">{lavoro.data.cliente}</span>
          <meta itemprop="position" content="3" />
        </li>
      </ol>
    </nav>
    <header class="case-hero" data-reveal style="transition-delay: 0ms;">
      <span class="section-label">(Case)</span>

      <div class="case-meta-row">
        <div class="case-meta-item">
          <span class="case-meta-label">(Cliente)</span>
          <span class="case-meta-value">{lavoro.data.cliente}</span>
        </div>
        <div class="case-meta-item">
          <span class="case-meta-label">(Settore)</span>
          <span class="case-meta-value">{lavoro.data.settore}</span>
        </div>
        <div class="case-meta-item">
          <span class="case-meta-label">(Durata)</span>
          <span class="case-meta-value">{lavoro.data.durata}</span>
        </div>
        <div class="case-meta-item">
          <span class="case-meta-label">(Ambito)</span>
          <span class="case-meta-value">{lavoro.data.ambito}</span>
        </div>
      </div>

      <h1 class="case-title">{lavoro.data.titolo}</h1>
      <p class="case-tesi">{lavoro.data.tesi}</p>

      {lavoro.data.heroImage ? (
        <div class="case-hero-image case-hero-image--reale">
          <img
            src={lavoro.data.heroImage}
            alt={lavoro.data.heroImageAlt || `Immagine del progetto ${lavoro.data.cliente}`}
            loading="eager"
            decoding="async"
          />
        </div>
      ) : (
        <div class="case-hero-image" role="presentation">
          <PixelCluster size="medium" variant="corner" color="arancio" />
        </div>
      )}
    </header>

    <div class="case-body" data-reveal>
      <Content
        components={{
          MediaImmagine,
          MediaGallery,
          MediaVideo,
        }}
      />
    </div>

    <footer class="case-footer" data-reveal>
      <PixelCluster size="medium" variant="separator" color="arancio" />

      <p style="margin-top: var(--space-6);">
        <a href="/contatti/" class="section-link">Parliamone insieme →</a>
      </p>

      <!-- Navigazione prev/next migliorata -->
      <nav class="case-navigation" aria-label="Altri case study">
        {casePrec ? (
          <a
            href={`/lavori/${casePrec.id}/`}
            class="case-nav-card case-nav-card--prev"
          >
            <span class="case-nav-card-label">← Case precedente</span>
            <span class="case-nav-card-cliente">{casePrec.data.cliente}</span>
            <span class="case-nav-card-titolo">{casePrec.data.titolo}</span>
          </a>
        ) : (
          <div class="case-nav-empty"></div>
        )}

        {caseSucc ? (
          <a
            href={`/lavori/${caseSucc.id}/`}
            class="case-nav-card case-nav-card--next"
          >
            <span class="case-nav-card-label">Case successivo →</span>
            <span class="case-nav-card-cliente">{caseSucc.data.cliente}</span>
            <span class="case-nav-card-titolo">{caseSucc.data.titolo}</span>
          </a>
        ) : (
          <div class="case-nav-empty"></div>
        )}
      </nav>

      <div style="text-align: center; margin-top: var(--space-8);">
        <a href="/lavori/" class="section-link">
          ← Tutti i lavori
        </a>
      </div>
    </footer>
  </article>
</BaseLayout>
