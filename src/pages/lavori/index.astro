---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PixelCluster from '../../components/visuals/PixelCluster.astro';
import TramaSfondo from '../../components/visuals/TramaSfondo.astro';
import '../../styles/pages/lavori.css';
import {
  archivioClienti,
  groupBySector
} from '../../data/archivio-clienti.ts';

const settoriArchivio = groupBySector(archivioClienti);

// Recupera tutti i case non-draft
const tuttiLavori = await getCollection('lavori', ({ data }) => !data.draft);

// Ordina per vetrina
const vetrina = tuttiLavori
  .filter(l => l.data.inVetrina)
  .sort((a, b) => (a.data.ordineVetrina || 999) - (b.data.ordineVetrina || 999));

const archivio = tuttiLavori
  .filter(l => !l.data.inVetrina);
---

<BaseLayout
  title="Lavori"
  description="I lavori selezionati di Mandarino. Case study strategici per clienti come AS Roma, Avio Interiors, Todis, Francia Latticini."
  path="/lavori/"
>
  <div class="lavori-page">
    <section class="lavori-hero reveal" style="position: relative;">
      <TramaSfondo variante="chiaro" opacita={0.05} />
      <div style="position: relative; z-index: 1;">
        <span class="section-label">(Lavori)</span>
        <h1 class="hero-title reveal">Quattro casi, quattro pensieri.</h1>
        <p class="lead reveal reveal-delay-1">Ogni progetto Mandarino parte da una domanda strategica. Qui ne vedete quattro, raccontati per quello che sono davvero.</p>
      </div>
    </section>

    <section class="vetrina-section" aria-labelledby="vetrina-title" class="reveal">
      <h2 id="vetrina-title" class="visually-hidden">Lavori in vetrina</h2>

      <div class="vetrina-grid">
        {vetrina.map((lavoro, index) => (
          <a href={`/lavori/${lavoro.id}/`} class={`vetrina-card reveal reveal-delay-${Math.min(index, 3)}`}>
            <div class="vetrina-card-image" aria-hidden="true">
              {lavoro.data.coverImage && (
                <img 
                  src={lavoro.data.coverImage} 
                  alt={lavoro.data.coverImageAlt || ""} 
                  loading="lazy"
                />
              )}
              <PixelCluster size="small" variant="corner" color="arancio" />
            </div>
            
            <div class="vetrina-card-content">
              <p class="vetrina-card-meta">
                {lavoro.data.cliente} Â· {lavoro.data.settore}
              </p>
              <h3 class="vetrina-card-title">{lavoro.data.titolo}</h3>
              <p class="vetrina-card-tesi">{lavoro.data.tesi}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ARCHIVIO CLIENTI STORICI -->
    <section
      class="archivio-section reveal"
      aria-labelledby="archivio-title"
      class="reveal"
      style="position: relative;"
    >
      <TramaSfondo variante="scuro" opacita={0.08} />
      
      <div style="position: relative; z-index: 1;">
        <PixelCluster size="large" variant="corner" color="arancio" />

      <div class="archivio-intro">
        <span class="section-label">(Archivio)</span>
        <h2 id="archivio-title">Vent'anni di clienti.</h2>
        <p>
          I case study in vetrina raccontano il nostro metodo in profondità.
          Qui trovate gli altri clienti con cui abbiamo lavorato
          in vent'anni di attività.
        </p>
      </div>

      <div class="archivio-settori">
        {Object.entries(settoriArchivio).map(([settore, clienti]) => (
          <div class="archivio-settore-gruppo">
            <p class="archivio-settore-nome">{settore}</p>
            <ul class="archivio-settore-lista">
              {clienti.map(cliente => (
                <li>
                  <span>{cliente.nome}</span>
                  {cliente.anno && (
                    <span class="archivio-anno">{cliente.anno}</span>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Anche i 4 case in vetrina compaiono nell'archivio
           come riferimento visivo alla vetrina sopra -->
      <p style="
        margin-top: var(--space-8);
        font-family: var(--font-ribelle);
        font-size: var(--text-sm);
        color: rgba(250, 247, 242, 0.45);
        font-style: italic;
      ">
        AS Roma, Avio Interiors, Todis e Gruppo Francia Latticini
        sono raccontati in dettaglio nella vetrina qui sopra.
      </p>
      </div>
    </section>
  </div>

</BaseLayout>
