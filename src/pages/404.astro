---
import BaseLayout from '../layouts/BaseLayout.astro';

// SVG del solo Ribelle — stesso design ma da solo, più grande
// e con espressione leggermente sorpresa/ironica
---

<BaseLayout
  title="Pagina non trovata"
  description="La pagina che cercate non esiste. Ma il Ribelle è qui."
  path="/404/"
>
  <div class="pagina-404">

    <div class="quattrozeroquattro-visual" aria-hidden="true">
      <svg viewBox="0 0 320 380" xmlns="http://www.w3.org/2000/svg"
           class="ribelle-solo">

        <!-- Sfondo scuro parziale (solo sotto il Ribelle) -->
        <ellipse cx="160" cy="340" rx="120" ry="28"
          fill="rgba(46,64,87,0.08)"/>

        <!-- Pixel sparsi — il Ribelle è da solo e i pixel
             sembrano un po' confusi anche loro -->
        <rect x="42"  y="48"  width="10" height="10"
          fill="#E87722" opacity="0.6" class="px px-a"/>
        <rect x="56"  y="60"  width="8"  height="8"
          fill="#E87722" opacity="0.4" class="px px-b"/>
        <rect x="256" y="54"  width="10" height="10"
          fill="#E87722" opacity="0.7" class="px px-c"/>
        <rect x="270" y="42"  width="7"  height="7"
          fill="#E87722" opacity="0.5" class="px px-d"/>
        <rect x="38"  y="280" width="8"  height="8"
          fill="#E87722" opacity="0.5" class="px px-e"/>
        <rect x="268" y="290" width="9"  height="9"
          fill="#E87722" opacity="0.6" class="px px-f"/>

        <!-- Corpo Ribelle -->
        <rect x="110" y="262" width="100" height="78" rx="5"
          fill="#3D566E"/>
        <line x1="110" y1="292" x2="210" y2="292"
          stroke="rgba(250,247,242,0.1)" stroke-width="1"/>

        <!-- Gambe -->
        <rect x="122" y="334" width="22" height="14" rx="3"
          fill="#2A3F52"/>
        <rect x="176" y="334" width="22" height="14" rx="3"
          fill="#2A3F52"/>

        <!-- Scarpe -->
        <rect x="118" y="344" width="28" height="10" rx="4"
          fill="#1A2A38"/>
        <rect x="174" y="344" width="28" height="10" rx="4"
          fill="#1A2A38"/>

        <!-- Braccio sinistro — mano alla guancia (espressione
             "mah, non so dove sono finito") -->
        <path d="M112 272 Q84 268 76 256 Q72 244 80 240"
          fill="none" stroke="#FAF7F2" stroke-width="3.5"
          stroke-linecap="round"/>
        <!-- Mano sulla guancia -->
        <circle cx="80" cy="238" r="8" fill="#FAF7F2" opacity="0.9"/>

        <!-- Braccio destro — alzato come al solito ma con
             un punto interrogativo vicino (pixel confusi) -->
        <path d="M208 270 Q234 250 240 228 Q242 216 234 212"
          fill="none" stroke="#FAF7F2" stroke-width="3.5"
          stroke-linecap="round" class="braccio-404"/>
        <circle cx="233" cy="210" r="8" fill="#FAF7F2" opacity="0.9"/>
        <!-- Punto interrogativo fatto di pixel -->
        <rect x="244" y="196" width="6" height="6"
          fill="#E87722" class="px punto-q-1"/>
        <rect x="252" y="188" width="6" height="6"
          fill="#E87722" class="px punto-q-2"/>
        <rect x="252" y="180" width="6" height="6"
          fill="#E87722" class="px punto-q-3"/>
        <rect x="244" y="172" width="6" height="6"
          fill="#E87722" class="px punto-q-4"/>
        <rect x="236" y="172" width="6" height="6"
          fill="#E87722" class="px punto-q-5"/>
        <rect x="236" y="180" width="6" height="6"
          fill="#E87722" class="px punto-q-6"/>
        <!-- Punto in basso -->
        <rect x="244" y="162" width="6" height="6"
          fill="#E87722" class="px punto-q-punto"/>

        <!-- Testa arancio -->
        <ellipse cx="160" cy="182" rx="58" ry="60"
          fill="#E87722"/>

        <!-- Texture -->
        <path d="M160 122 Q152 152 160 182 Q168 152 160 122"
          fill="none" stroke="rgba(255,255,255,0.18)"
          stroke-width="1.5"/>
        <path d="M147 124 Q134 154 140 182"
          fill="none" stroke="rgba(255,255,255,0.1)"
          stroke-width="1"/>
        <path d="M173 124 Q186 154 180 182"
          fill="none" stroke="rgba(255,255,255,0.1)"
          stroke-width="1"/>

        <!-- Fogliolina -->
        <path d="M160 121 Q154 108 160 103 Q166 108 160 121"
          fill="#C0551A"/>

        <!-- CUFFIE -->
        <path d="M102 180 Q102 114 160 114 Q218 114 218 180"
          fill="none" stroke="#2E4057" stroke-width="6"
          stroke-linecap="round"/>
        <rect x="89"  y="170" width="18" height="26" rx="6"
          fill="#2E4057" stroke="#FAF7F2" stroke-width="1.5"/>
        <rect x="213" y="170" width="18" height="26" rx="6"
          fill="#2E4057" stroke="#FAF7F2" stroke-width="1.5"/>

        <!-- Occhi — uno alzato (sopracciglio alzato, espressione
             ironica "ma come sei arrivato qui?") -->
        <!-- Occhio sinistro normale -->
        <circle cx="146" cy="180" r="6.5" fill="#2E4057"/>
        <circle cx="148" cy="178" r="2.5" fill="#FAF7F2"/>
        <!-- Occhio destro con sopracciglio alzato -->
        <circle cx="174" cy="178" r="6.5" fill="#2E4057"/>
        <circle cx="176" cy="176" r="2.5" fill="#FAF7F2"/>
        <!-- Sopracciglio alzato (arco) -->
        <path d="M168 166 Q174 162 180 166"
          fill="none" stroke="#2E4057" stroke-width="2"
          stroke-linecap="round"/>

        <!-- Sorriso ironico (storto) -->
        <path d="M146 198 Q160 207 176 200"
          fill="none" stroke="#2E4057" stroke-width="2.5"
          stroke-linecap="round"/>

        <!-- Led microfono -->
        <circle cx="232" cy="193" r="4" fill="#E87722" class="led"/>

      </svg>
    </div>

    <div class="quattrozeroquattro-testo">
      <p class="quattrozeroquattro-numero">404</p>
      <h1 class="quattrozeroquattro-titolo">
        Il Saggio non è qui.
      </h1>
      <p class="quattrozeroquattro-sottotitolo">
        Forse sta meditando.
      </p>
      <a href="/" class="quattrozeroquattro-link">
        ← Torna alla home
      </a>
    </div>

  </div>
</BaseLayout>

<style>
  .pagina-404 {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    padding: var(--space-12) var(--space-4);
    text-align: center;
    gap: var(--space-8);
  }

  .quattrozeroquattro-visual {
    max-width: 280px;
    width: 100%;
  }

  .ribelle-solo {
    width: 100%;
    height: auto;
  }

  .quattrozeroquattro-numero {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-arancio-ribelle);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-2);
  }

  .quattrozeroquattro-titolo {
    font-family: var(--font-saggio);
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    color: var(--color-grigio-saggio);
    margin-bottom: var(--space-2);
    letter-spacing: -0.01em;
  }

  .quattrozeroquattro-sottotitolo {
    font-family: var(--font-saggio);
    font-style: italic;
    font-size: var(--text-xl);
    color: var(--color-grigio-saggio-soft);
    margin-bottom: var(--space-6);
  }

  .quattrozeroquattro-link {
    font-family: var(--font-ribelle);
    font-size: var(--text-base);
    color: var(--color-grigio-saggio);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    transition: color var(--transition-quick);
  }

  .quattrozeroquattro-link:hover {
    color: var(--color-arancio-ribelle);
  }

  /* Animazioni pixel — un po' più frenetiche del solito
     il Ribelle è solo e un po' confuso */
  .px {
    animation: px-confused 2.2s ease-in-out infinite;
  }
  .px-a { animation-delay: 0ms; }
  .px-b { animation-delay: 300ms; }
  .px-c { animation-delay: 150ms; }
  .px-d { animation-delay: 450ms; }
  .px-e { animation-delay: 200ms; }
  .px-f { animation-delay: 350ms; }
  .punto-q-1 { animation-delay: 0ms; }
  .punto-q-2 { animation-delay: 100ms; }
  .punto-q-3 { animation-delay: 200ms; }
  .punto-q-4 { animation-delay: 300ms; }
  .punto-q-5 { animation-delay: 400ms; }
  .punto-q-6 { animation-delay: 500ms; }
  .punto-q-punto {
    animation: punto-blink 1.8s ease-in-out infinite;
  }

  @keyframes px-confused {
    0%, 100% { opacity: 0.7; transform: translateY(0); }
    30%       { opacity: 0.2; transform: translateY(-3px); }
    60%       { opacity: 0.9; transform: translateY(2px); }
  }

  @keyframes punto-blink {
    0%, 60%, 100% { opacity: 1; }
    80%            { opacity: 0; }
  }

  .braccio-404 {
    animation: braccio-gratta 3s ease-in-out infinite;
    transform-origin: 208px 270px;
  }
  @keyframes braccio-gratta {
    0%, 100% { transform: rotate(0deg); }
    40%       { transform: rotate(-5deg); }
    70%       { transform: rotate(3deg); }
  }

  .led {
    animation: led-blink 3s ease-in-out infinite;
  }
  @keyframes led-blink {
    0%, 85%, 100% { opacity: 1; }
    90%            { opacity: 0.1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .px, .punto-q-punto, .braccio-404, .led {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
