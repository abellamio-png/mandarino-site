# Normalize line endings to LF on commit
* text=auto eol=lf

# Force LF for source files
*.astro text eol=lf
*.css text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.ts text eol=lf
*.md text eol=lf
*.json text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.woff binary
*.woff2 binary
